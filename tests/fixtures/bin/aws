#!/bin/bash
# Fake aws CLI for integration tests

case "$1 $2" in
  "sts get-caller-identity")
    echo '{"Account":"123456789012","Arn":"arn:aws:sts::123456789012:assumed-role/developer/testdev","UserId":"AROAXXXXXXXXX:testdev"}'
    exit 0
    ;;
  "--version"*)
    echo "aws-cli/2.15.0"
    exit 0
    ;;
  *)
    echo "mock aws: unhandled '$*'" >&2
    exit 1
    ;;
esac
