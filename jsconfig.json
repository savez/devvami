{
  "compilerOptions": {
    "checkJs": true,
    "strict": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "allowJs": true,
    "lib": ["ESNext"],
    "baseUrl": ".",
    "paths": {
      "#src/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.js", "tests/**/*.js"],
  "exclude": ["node_modules"]
}
